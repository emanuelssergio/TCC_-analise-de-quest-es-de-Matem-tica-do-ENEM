         \"\\u00c1lgebra e Fun\\u00e7\\u00f5es\",\n          \"Proporcionalidade e Varia\\u00e7\\u00e3o\",\n          \"Geometria\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"}},"metadata":{}}]},{"cell_type":"code","source":["import pandas as pd\n","from collections import Counter, defaultdict\n","import math\n","\n","# --- Lê o CSV base ---\n","arquivo = \"/content/gabarito2023.csv\"\n","df = pd.read_csv(arquivo, encoding=\"latin-1\")\n","\n","# -------------------------------------------------------------------\n","# 1) Limpeza, remoção de stopwords e lematização simples\n","# -------------------------------------------------------------------\n","\n","STOPWORDS = {\n","    \"de\", \"da\", \"do\", \"das\", \"dos\", \"em\", \"no\", \"na\", \"nos\", \"nas\",\n","    \"para\", \"por\", \"com\", \"uma\", \"umas\", \"um\", \"uns\", \"ao\", \"aos\",\n","    \"e\", \"o\", \"a\", \"que\", \"se\", \"ser\", \"são\", \"como\", \"onde\", \"qual\",\n","    \"quando\", \"sobre\", \"entre\", \"pelo\", \"pela\", \"pelos\", \"pelas\"\n","}\n","\n","# mapa de simplificação (reduz variações das palavras)\n","STEM_MAP = {\n","    \"medidas\": \"medida\",\n","    \"medidos\": \"medido\",\n","    \"gráficos\": \"gráfico\",\n","    \"gráfica\": \"gráfico\",\n","    \"funções\": \"função\",\n","    \"equações\": \"equação\",\n","}\n","\n","PONTOS = str.maketrans({c: \" \" for c in \",.;:!?()[]{}\\\"'ºª“”\"})\n","\n","def limpar_texto(txt):\n","    palavras = str(txt).lower().translate(PONTOS).split()\n","    limp = []\n","    for p in palavras:\n","        if len(p) <= 2 or p in STOPWORDS:\n","            continue\n","        # reduz palavras flexionadas\n","        p = STEM_MAP.get(p, p)\n","        limp.append(p)\n","    return limp\n","\n","# -------------------------------------------------------------------\n","# 2) Calculando TF, DF e IDF\n","# -------------------------------------------------------------------\n","\n","documentos = [limpar_texto(t) for t in df[\"corpo_questao\"]]\n","\n","tfs = [Counter(doc) for doc in documentos]\n","\n","dfreq = defaultdict(int)\n","for doc in documentos:\n","    for termo in doc:\n","        dfreq[termo] += 1\n","\n","N = len(documentos)\n","idf = {termo: math.log(N / (1 + freq)) for termo, freq in dfreq.items()}\n","\n","def tfidf_vector(tf):\n","    return {termo: tf[termo] * idf.get(termo, 0) for termo in tf}\n","\n","# -------------------------------------------------------------------\n","# 3) Vocabulário por área\n","# -------------------------------------------------------------------\n","\n","areas_vocab = {\n","\n","\n","\n","    \"Aritmética\": [\n","        \"número\",\"contar\",\"soma\",\"diferença\",\"fração\",\n","        \"razão\",\"proporção\",\"potência\",\"exponencial\",\n","        \"percentual\",\"probabilidade\",\"redução\",\n","        \"unidade\",\"inteiro\",\"decimal\",\n","        \"consumo\",\"total\",\"economizar\",\n","        \"dias\",\"horas\",\"ano\",\"anos\"\n","    ],\n","\n","    \"Geometria\": [\n","        \"ponto\",\"reta\",\"segmento\",\"triângulo\",\"quadrado\",\"retângulo\",\n","        \"ângulo\",\"perpendicular\",\"paralelo\",\"círculo\",\"circunferência\",\n","        \"cone\",\"cilindro\",\"esfera\",\"raio\",\"diâmetro\",\n","        \"área\",\"volume\",\"polígono\",\"altura\",\"base\",\n","        \"coordenada\",\"distância\",\"projeção\",\n","        \"poligonal\",\"semicírculo\",\"coluna\",\"fila\",\"trave\"\n","    ],\n","\n","    \"Grandezas e Medidas\": [\n","        \"metro\",\"centímetro\",\"quilômetro\",\n","        \"litro\",\"mililitro\",\"volume\",\"área\",\n","        \"altura\",\"largura\",\"comprimento\",\"profundidade\",\n","        \"velocidade\",\"pressão\",\"massa\",\"vazão\",\n","        \"capacidade\",\"escala\",\"reservatório\",\n","        \"litros por minuto\",\"capacidade máxima\",\n","        \"diâmetro interno\",\"superfície\"\n","    ],\n","\n","    \"Proporcionalidade e Variação\": [\n","        \"proporção\",\"proporcional\",\"razão\",\"variação\",\n","        \"velocidades\",\"constante\",\"linear\",\n","        \"ciclo\",\"ritmo\",\"relação\",\"aumento\",\"diminuição\",\n","        \"intervalo\",\"tempos\",\"minutos\",\"horas\",\n","        \"proporcionalidade direta\",\"proporcionalidade inversa\",\n","        \"razão constante\",\"escala de tempo\",\n","        \"taxa fixa\",\"consumo diário\",\"por minuto\",\"por unidade\"\n","    ],\n","\n","    \"Álgebra e Funções\": [\n","        \"função\",\"equação\",\"expressão\",\"variável\",\n","        \"função afim\",\"função quadrática\",\"função crescente\",\n","        \"função decrescente\",\"parábola\",\"coeficiente\",\n","        \"representação\",\"modelo\",\"raiz\",\"sistema\",\"incógnita\",\n","        \"logaritmo\",\"linear\",\"progressão\",\n","        \"variação linear\",\"dependente\",\"independente\"\n","    ],\n","\n","    \"Gráficos e Tabelas\": [\n","        \"gráfico\",\"tabela\",\"barra\",\"linha\",\"pizza\",\"curva\",\n","        \"pontos\",\"cartesiano\",\"eixo\",\"coordenada\",\"malha\",\n","        \"legenda\",\"colunas\",\"frequência\",\"amplitude\",\"diagrama\",\n","        \"eixo x\",\"eixo y\",\"dispersão\",\n","        \"variação temporal\",\"perfil\",\"tendência\",\n","        \"tendência linear\",\"sequência gráfica\"\n","    ],\n","\n","    \"Estatística e Probabilidade\": [\n","        \"probabilidade\",\"evento\",\"amostra\",\"população\",\n","        \"média\",\"mediana\",\"moda\",\"frequência\",\n","        \"tabela\",\"distribuição\",\"percentual\",\n","        \"chance\",\"estimativa\",\"desvio\",\"intervalo\",\n","        \"variância\",\"experimento\",\"aleatório\",\n","        \"sorteio\",\"urna\",\"tendência\"\n","    ]\n","\n","}\n","\n","# --- Expansão automática: pega sinônimos frequentes no corpus ---\n","for area, palavras in areas_vocab.items():\n","    for termo in list(palavras):\n","        base = termo[:5]   # reduz palavra a um prefixo\n","        relacionados = [t for t in dfreq if t.startswith(base) and t not in palavras]\n","        palavras.extend(relacionados[:3])   # adiciona até 3 similares\n","\n","# -------------------------------------------------------------------\n","# 4) Vetores TF-IDF das áreas + reforço de peso\n","# -------------------------------------------------------------------\n","\n","tfidf_areas = {}\n","for area, palavras in areas_vocab.items():\n","    cont = Counter(palavras)\n","    vec = tfidf_vector(cont)\n","    for k in vec:  # reforça o peso das palavras-chave\n","        vec[k] *= 1.5\n","    tfidf_areas[area] = vec\n","\n","# -------------------------------------------------------------------\n","# 5) Similaridade do cosseno\n","# -------------------------------------------------------------------\n","\n","def similaridade(v1, v2):\n","    comum = set(v1.keys()) & set(v2.keys())\n","    num = sum(v1[t] * v2[t] for t in comum)\n","    den1 = math.sqrt(sum(v*v for v in v1.values()))\n","    den2 = math.sqrt(sum(v*v for v in v2.values()))\n","    return num / (den1 * den2) if den1 and den2 else 0\n","\n","# -------------------------------------------------------------------\n","# 6) Classificador otimizado\n","# -------------------------------------------------------------------\n","\n","def classificar_tfidf(texto):\n","    palavras = limpar_texto(texto)\n","    tfidf_q = tfidf_vector(Counter(palavras))\n","\n","    melhor_area = None\n","    melhor_sim = -1\n","\n","    for area, vetor in tfidf_areas.items():\n","        sim = similaridade(tfidf_q, vetor)\n","        if sim > melhor_sim:\n","            melhor_sim = sim\n","            melhor_area = area\n","\n","    return melhor_area\n","\n","# -------------------------------------------------------------------\n","# 7) Classificar todas as questões\n","# -------------------------------------------------------------------\n","\n","coluna_nome = \"classificacao_tfidf\"\n","df[coluna_nome] = df[\"corpo_questao\"].apply(classificar_tfidf)\n","\n","print(df[[\"numero_questao\", \"corpo_questao\", coluna_nome]].head())\n","\n","saida = \"/content/questoes_enem_classificacoes.csv\"\n","df.to_csv(saida, index=False, encoding=\"latin-1\")\n","print(f\"\\nCSV salvo em: {saida}\")\n","print(df[coluna_nome].value_counts())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"93PgbEf7lswc","executionInfo":{"status":"ok","timestamp":1769866546770,"user_tz":180,"elapsed":48,"user":{"displayName":"emanuel silva sergio","userId":"02349990647292232610"}},"outputId":"b61ce4dc-00d3-4b12-d511-4f41aa93a523","collapsed":true},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["   numero_questao                                      corpo_questao  \\\n","0             136  Uma pessoa comprou um ingresso para o cinema e...   \n","1             137  O metrô de um município oferece dois tipos de ...   \n","2             138  O gráfico expõe alguns números da gripe A-H1N1...   \n","3             139  A figura representa uma escada com três degrau...   \n","4             140  Um supermercado conta com cinco caixas disponí...   \n","\n","  classificacao_tfidf  \n","0           Geometria  \n","1  Gráficos e Tabelas  \n","2          Aritmética  \n","3           Geometria  \n","4           Geometria  \n","\n","CSV salvo em: /content/questoes_enem_classificacoes.csv\n","classificacao_tfidf\n","Geometria                       10\n","Estatística e Probabilidade      9\n","Aritmética                       7\n","Proporcionalidade e Variação     7\n","Grandezas e Medidas              6\n","Álgebra e Funções                4\n","Gráficos e Tabelas               2\n","Name: count, dtype: int64\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"zOX2rHz6ZfRW"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["dfc= pd.read_csv('/content/questoes_enem_classificacoes.csv', encoding='latin-1')\n","dfc.head()"],"metadata":{"colab":{"base_uri":"https://lo