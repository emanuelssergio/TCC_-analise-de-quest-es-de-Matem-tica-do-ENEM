   \"description\": \"\"\n      }\n    }\n  ]\n}"}},"metadata":{},"execution_count":7}]},{"cell_type":"code","source":["import pandas as pd\n","\n","# ----------------------------------------------------\n","# 1) Função para comparar respostas com o gabarito\n","# ----------------------------------------------------\n","def comparar_respostas(respostas, gabarito):\n","    \"\"\"\n","    Compara resposta do aluno com o gabarito.\n","    Retorna uma lista:\n","    1 -> acerto\n","    0 -> erro ou questão em branco\n","    \"\"\"\n","    return [\n","        1 if r == g and r != \".\" else 0\n","        for r, g in zip(respostas, gabarito)\n","    ]\n","\n","\n","# ----------------------------------------------------\n","# 2) Gera a matriz de acertos (alunos x questões)\n","# ----------------------------------------------------\n","def gerar_matriz_acertos_mt(df):\n","    \"\"\"\n","    Retorna DataFrame:\n","    linhas  -> alunos\n","    colunas -> Q1, Q2, ..., Q45\n","    \"\"\"\n","\n","    matriz = df.apply(\n","        lambda row: comparar_respostas(\n","            row[\"TX_RESPOSTAS_MT\"],\n","            row[\"TX_GABARITO_MT\"]\n","        ),\n","        axis=1\n","    )\n","\n","    df_acertos = pd.DataFrame(matriz.tolist())\n","    df_acertos.columns = [f\"Q{i+1}\" for i in range(df_acertos.shape[1])]\n","\n","    return df_acertos\n","\n","\n","# ----------------------------------------------------\n","# 3) Pipeline completo (uso final)\n","# ----------------------------------------------------\n","def analisar_acertos_matematica(df):\n","    \"\"\"\n","    Retorna:\n","    - df_resultado -> porcentagem e quantidade de acertos por questão\n","    - df_acertos   -> matriz aluno x questão (0/1)\n","    \"\"\"\n","\n","    df_acertos = gerar_matriz_acertos_mt(df)\n","\n","    quantidade_acertos = df_acertos.sum()\n","    porcentagem_acertos = df_acertos.mean() * 100\n","\n","    df_resultado = pd.DataFrame({\n","        \"questao\": quantidade_acertos.index,\n"